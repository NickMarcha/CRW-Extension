{
  "name": "crw-ext",
  "version": "1.0.0",
  "license": "MIT",
  "author": "jake@fulu.org",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npm run update:country-codes",
    "prebuild": "npm run update:country-codes",
    "prelint": "npm run update:country-codes",
    "pretest": "npm run update:country-codes",
    "build": "npm run build-chrome && npm run build-firefox",
    "build-firefox": "cross-env BROWSER=firefox vite build --config vite.background.config.ts && cross-env BROWSER=firefox vite build --config vite.config.ts",
    "build-chrome": "cross-env BROWSER=chrome vite build --config vite.background.config.ts && cross-env BROWSER=chrome vite build --config vite.config.ts",
    "build:watch": "chokidar \"src/**/*\" -i \"src/generated/**\" -c \"npm run build\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "match:preview": "node --experimental-strip-types scripts/url-match-preview.ts",
    "match:compare-subdomains": "node --experimental-strip-types scripts/compare-subdomain-matching.ts",
    "match:compare-tlds": "node --experimental-strip-types scripts/compare-tld-matching.ts",
    "verify:matching": "node --experimental-strip-types scripts/verify-matching.ts",
    "verify:cargo-quality": "node --experimental-strip-types scripts/verify-cargo-quality.ts",
    "update:country-codes": "node --experimental-strip-types scripts/update-country-code-suffixes.ts",
    "update-version": "node --experimental-strip-types scripts/update-version.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage tests/*.test.ts",
    "server:dev": "cd server && npx tsx watch src/index.ts",
    "server:start": "cd server && npx tsx src/index.ts"
  },
  "dependencies": {
    "he": "^1.2.0",
    "i18n-iso-countries": "^7.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tldts": "^7.0.23",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/he": "^1.2.3",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/webextension-polyfill": "^0.12.4",
    "@vitejs/plugin-react": "^5.1.0",
    "chokidar-cli": "^3.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "mwn": "^3.0.1",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.1.12",
    "vite-plugin-static-copy": "^3.1.4"
  }
}
